// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  password              String
  name                  String?
  profilePictureUrl     String?
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  persona               Persona?
  generations           Generation[]
  founderPage           FounderPage?
}

// Persona model
model Persona {
  id              String   @id @default(uuid())
  userId          String   @unique
  bio             String?
  industry        String?
  targetAudience  String?
  brandTone       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaImages   PersonaImage[]
}

// Persona Images model
model PersonaImage {
  id        String   @id @default(uuid())
  personaId String
  imageUrl  String
  createdAt DateTime @default(now())
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

// Generation model (for both images and text)
model Generation {
  id            String   @id @default(uuid())
  userId        String
  type          String
  prompt        String
  model         String
  result        String?
  status        String   @default("pending")
  errorMessage  String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FounderPage {
  id          String   @id @default(uuid())
  userId      String   @unique
  username    String   @unique
  template    String   @default("visionary") // 'visionary', 'storyteller', 'expert', 'creator'
  published   Boolean  @default(false)
  
  // JSON fields for flexibility
  design      Json?    // {titleFont, bodyFont, primaryColor, secondaryColor}
  basicInfo   Json?    // {name, title, tagline, about1, about2, heroImageUrl, logoUrl}
  contact     Json?    // {email, phone, location, social1, social2, ctaText, ctaDescription}
  services    Json?    // [{id, title, description}, ...]
  portfolio   Json?    // {images: [{id, url}, ...]}
  featured    Json?    // [{id, title, subtitle, year, imageUrl}, ...]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([username])
}